{
  "manifest_version": 3,
  "key": "",
  "name": "Pratibimb",
  "version": "1.4.3",
  "version_name": "Commit 43",
  "description": "Syncs your new tab with the Windows desktop wallpaper.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "nativeMessaging",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://suggestqueries.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://grok.com/*",
        "*://x.com/*"
      ],
      "js": ["ai_autosubmit.js"],
      "run_at": "document_idle"
    }
  ]
}